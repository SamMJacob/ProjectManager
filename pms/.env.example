# Django
SECRET_KEY=replace-me-with-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,your-app.railway.app

# Database — Railway injects this automatically, leave blank for local SQLite
DATABASE_URL=

# CORS — set to your Vercel frontend URL in production
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-app.vercel.app
CSRF_TRUSTED_ORIGINS=http://localhost:5173,https://your-app.vercel.app

# Frontend URL — used in email invitation links
FRONTEND_URL=https://your-app.vercel.app

# Email (Gmail SMTP)
EMAIL_HOST_USER=you@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
